APP_ENV=development
APP_DEBUG=true

API_V1_PREFIX=/api/v1
PROJECT_NAME=peso-tugma-ai

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# MongoDB
# Provide credentials/host as components; the app URL-encodes them and assembles
# MONGODB_URI (see app/core/config.py). For MongoDB Atlas use MONGODB_SCHEME=mongodb+srv
# and a hostname without a port (e.g. cluster0.xxxxx.mongodb.net).
# To pass a full connection string instead, set MONGODB_URI directly (already escaped).
MONGODB_USERNAME=username
MONGODB_PASSWORD=password
MONGODB_SCHEME=mongodb
MONGODB_HOST=localhost:27017
MONGODB_OPTIONS=
MONGODB_DB_NAME=peso_tugma_ai

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth cookies (httpOnly). Keep COOKIE_SECURE=false for local http; set true in
# production (HTTPS). Use COOKIE_SAMESITE=none (with secure=true) only for a
# cross-site frontend domain.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
